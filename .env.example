# Seguridad de Django
SECRET_KEY='tu-secret-key-aqui'
DEBUG=True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Configuración de Base de Datos PostgreSQL
DB_NAME=ColonScan
DB_USER=postgres
DB_PASSWORD=tu-contraseña
DB_HOST=localhost
DB_PORT=5432

# Configuración de Google Cloud Platform (GCP) con ADC
# ====================================================
# AUTENTICACIÓN: Application Default Credentials

# Habilitar Google Cloud Storage
GCS_ENABLED=True

# Nombre del bucket de Google Cloud Storage (requerido)
GCS_BUCKET_NAME=tu-bucket-colonscan

# Prefijo de carpeta para archivos en GCS (opcional)
# Los archivos se guardarán en: {GCS_BUCKET_NAME}/{GCS_EVIDENCE_PREFIX}/{evaluation_id}/{filename}
GCS_EVIDENCE_PREFIX=evaluations/ctc_scans

# Verificación posterior a la subida (antes de llamar a la API)
# Cantidad de reintentos para confirmar que el objeto existe en GCS
GCS_VERIFY_MAX_RETRIES=3
# Tiempo base (segundos) entre reintentos de verificación
GCS_VERIFY_RETRY_DELAY_SECONDS=1

# Si usas ADC de usuario y no tienes clave privada para signed URL,
# puedes publicar el objeto para que la API lo lea por HTTPS.
# (True: hace público cada archivo subido, False: no lo publica)
GCS_MAKE_PUBLIC_ON_UPLOAD=True

# CREDENCIALES CON ADC (Application Default Credentials)
# ========================================================
# NO debes pasar credenciales aquí. En su lugar, sigue estos pasos:
#
# EN DESARROLLO (Docker):
#   1. docker compose up -d                                          # Inicia el servicio web
#   2. docker compose exec -it web gcloud auth login                 # Autentica con tu cuenta
#   3. docker compose exec web gcloud config set project PROJECT_ID
#   4. docker compose exec -it web gcloud auth application-default login
#   5. docker compose exec web gcloud auth application-default set-quota-project PROJECT_ID
#
# Las credenciales se guardan en el volumen 'gcloud-config' (/home/appuser/.config/gcloud)
# y persisten entre reinicios del contenedor.
#
# Si bajas el contenedor (docker compose down):
#   - Las credenciales se pierden, debes repetir los pasos 4-5 cuando levantes de nuevo
#
# ALTERNATIVA PARA PRODUCCIÓN (Cuenta de Servicio):
#   - Monta un JSON de cuenta de servicio como variable de entorno:
#     GOOGLE_APPLICATION_CREDENTIALS=/secret/gcp-key.json
#   - O pasa la ruta en esta variable (si usas JSON):
#     GCP_CREDENTIALS_JSON=/path/to/service-account-key.json

# (Dejar vacío - ADC se detecta automáticamente desde ~/.config/gcloud)
# GCP_CREDENTIALS_JSON=

# Configuración de API del Modelo de Análisis (AHORA RECIBE URL, NO ARCHIVO)
# URL de la API donde se enviarán las URLs de los archivos en GCS para análisis
# En desarrollo local: http://localhost:8001/api/v1/analyze
# En Docker: http://host.docker.internal:8001/api/v1/analyze
# La API recibirá un JSON con la URL del archivo en GCS, no el archivo en sí
API_URL=http://host.docker.internal:8001/api/v1/analyze

# URL base de la API para consultar estado de tareas
# En desarrollo local: http://localhost:8001/api/v1
# En Docker: http://host.docker.internal:8001/api/v1
API_BASE_URL=http://host.docker.internal:8001/api/v1

# Timeout en segundos para las solicitudes a la API
API_TIMEOUT=900

# Clave API si tu servicio lo requiere (opcional)
API_KEY=

# Verificar certificados SSL (True para producción, False para desarrollo)
API_ENABLE_SSL_VERIFY=False

# Límite de carga que aceptará Django (en MB)
# En Compute Engine puedes subir este valor para archivos médicos pesados.
MAX_UPLOAD_MB=1024

# Umbral para mantener archivos en memoria (bytes)
# Archivos más grandes se escriben temporalmente en disco.
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Variables opcionales para crear admin demo con el comando seed_data
# Si no se definen, el comando no crea superusuario.
DEMO_ADMIN_USERNAME=
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=
