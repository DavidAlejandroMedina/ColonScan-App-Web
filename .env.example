# Seguridad de Django
SECRET_KEY='tu-secret-key-aqui'
DEBUG=True

# Configuración de Base de Datos PostgreSQL
DB_NAME=ColonScan
DB_USER=postgres
DB_PASSWORD=tu-contraseña
DB_HOST=localhost
DB_PORT=5432

# Configuración de API del Modelo de Análisis
# URL de la API donde se enviarán los archivos ZIP para análisis
# En desarrollo local: http://localhost:8001/api/v1/analyze
# En Docker: http://host.docker.internal:8001/api/v1/analyze
API_URL=http://host.docker.internal:8001/api/v1/analyze

# URL base de la API para consultar estado de tareas
# En desarrollo local: http://localhost:8001/api/v1
# En Docker: http://host.docker.internal:8001/api/v1
API_BASE_URL=http://host.docker.internal:8001/api/v1

# Timeout en segundos para las solicitudes a la API
API_TIMEOUT=30

# Clave API si tu servicio lo requiere (opcional)
API_KEY=

# Verificar certificados SSL (True para producción, False para desarrollo)
API_ENABLE_SSL_VERIFY=False
