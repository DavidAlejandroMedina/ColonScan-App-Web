# Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=YOUR_VM_EXTERNAL_IP,YOUR_DOMAIN
CSRF_TRUSTED_ORIGINS=http://YOUR_VM_EXTERNAL_IP,https://YOUR_DOMAIN

# Upload behavior on Compute Engine
MAX_UPLOAD_MB=1024
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Cloud SQL (private IP recommended)
DB_NAME=ColonScan
DB_USER=postgres
DB_PASSWORD=replace-db-password
DB_HOST=10.0.0.5
DB_PORT=5432

# Google Cloud Storage
GCS_ENABLED=True
GCS_BUCKET_NAME=your-colonscan-bucket
GCS_EVIDENCE_PREFIX=evaluations/ctc_scans
GCS_VERIFY_MAX_RETRIES=3
GCS_VERIFY_RETRY_DELAY_SECONDS=1
GCS_MAKE_PUBLIC_ON_UPLOAD=False

# API model service
API_URL=https://your-api-domain/api/v1/analyze
API_BASE_URL=https://your-api-domain/api/v1
API_TIMEOUT=900
API_KEY=
API_ENABLE_SSL_VERIFY=True

# Optional demo admin for seed command (do not use weak passwords in prod)
DEMO_ADMIN_USERNAME=
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=
